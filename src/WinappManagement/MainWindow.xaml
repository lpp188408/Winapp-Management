<Window x:Class="WinappManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:WinappManagement.Models"
        Title="Winapp Management"
        Width="1280"
        Height="760"
        MinWidth="1080"
        MinHeight="620"
        Background="#F6F8FB"
        FontFamily="Microsoft YaHei UI, Segoe UI"
        FontSize="12"
        Icon="assets/app-logo.ico"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <CollectionViewSource x:Key="ApplicationItemsViewSource" Source="{Binding Items}">
      <CollectionViewSource.GroupDescriptions>
        <PropertyGroupDescription PropertyName="ApplicationGroupName" />
      </CollectionViewSource.GroupDescriptions>
    </CollectionViewSource>
    <CollectionViewSource x:Key="OfficeItemsViewSource" Source="{Binding Items}" />

    <SolidColorBrush x:Key="LineBrush" Color="#D7DEE8" />
    <SolidColorBrush x:Key="SoftLineBrush" Color="#E8EDF4" />
    <SolidColorBrush x:Key="PanelBrush" Color="White" />
    <SolidColorBrush x:Key="PageBrush" Color="#F6F8FB" />

    <Style TargetType="Button">
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="BorderBrush" Value="#BBD7FF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="#EEF6FF" />
      <Setter Property="Foreground" Value="#1D4ED8" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="MinWidth" Value="50" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    SnapsToDevicePixels="True">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#DBEAFF" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#93C5FD" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#C7DEFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#94A3B8" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E2E8F0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#D9ECFF" />
      <Setter Property="BorderBrush" Value="#93C5FD" />
      <Setter Property="Foreground" Value="#1D4ED8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    SnapsToDevicePixels="True">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#C7DEFF" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#60A5FA" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#BBD7FF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#94A3B8" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E2E8F0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Background" Value="White" />
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="GridLinesVisibility" Value="All" />
      <Setter Property="VerticalGridLinesBrush" Value="{StaticResource SoftLineBrush}" />
      <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource SoftLineBrush}" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="CanUserResizeRows" Value="False" />
      <Setter Property="IsReadOnly" Value="False" />
      <Setter Property="RowHeight" Value="46" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="SelectionUnit" Value="FullRow" />
      <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
      <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
      <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
      <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel" />
    </Style>

    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="White" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#EAF3FF" />
          <Setter Property="Foreground" Value="#102033" />
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#F3F8FF" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#F1F5F9" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="BorderBrush" Value="{StaticResource SoftLineBrush}" />
      <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

    <Style TargetType="DataGridCell">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#EAF3FF" />
          <Setter Property="Foreground" Value="#102033" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SelectionDataGridCellStyle" TargetType="DataGridCell" BasedOn="{StaticResource {x:Type DataGridCell}}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="CellTextStyle" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="Foreground" Value="#102033" />
    </Style>

    <Style x:Key="CenterCellTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CellTextStyle}">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="FontWeight" Value="Normal" />
    </Style>

    <Style x:Key="BadgeStyle" TargetType="Border">
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="SmallIconButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="Foreground" Value="#B45309" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="FavoriteButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="30" />
      <Setter Property="Padding" Value="6,2" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#FACC15" />
      <Setter Property="Foreground" Value="#B45309" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    SnapsToDevicePixels="True">
              <ContentPresenter Margin="{TemplateBinding Padding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="#94A3B8" />
                <Setter TargetName="ButtonBorder" Property="Background" Value="#F8FAFC" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#E2E8F0" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
          <Setter Property="Background" Value="#FACC15" />
          <Setter Property="BorderBrush" Value="#F59E0B" />
          <Setter Property="Foreground" Value="#78350F" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
      <Setter Property="MinWidth" Value="46" />
      <Setter Property="Padding" Value="7,3" />
    </Style>

    <Style x:Key="LinkButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#2563EB" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="Center"
                              RecognizesAccessKey="True" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SelectionCellButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="SelectionCellButtonBorder"
                    Background="{TemplateBinding Background}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="SelectionCellButtonBorder" Property="Background" Value="#F3F8FF" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="SelectionCellButtonBorder" Property="Background" Value="#EAF3FF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TabControl">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="TabItem">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder"
                    Background="#F8FAFC"
                    BorderBrush="Transparent"
                    BorderThickness="1,1,1,0"
                    CornerRadius="10,10,0,0"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#60A5FA" />
                <Setter Property="Foreground" Value="#1D4ED8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AppTabItemStyle" TargetType="TabItem">
      <Setter Property="Padding" Value="16,10" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#334155" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="#F8FAFC" BorderBrush="Transparent" BorderThickness="1,1,1,0" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#60A5FA" />
                <Setter Property="Foreground" Value="#1D4ED8" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="OfficeTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource AppTabItemStyle}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="#F8FAFC" BorderBrush="Transparent" BorderThickness="1,1,1,0" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#A78BFA" />
                <Setter Property="Foreground" Value="#7C3AED" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FavoriteTabItemStyle" TargetType="TabItem" BasedOn="{StaticResource AppTabItemStyle}">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="#F8FAFC" BorderBrush="Transparent" BorderThickness="1,1,1,0" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="White" />
                <Setter TargetName="TabBorder" Property="BorderBrush" Value="#F59E0B" />
                <Setter Property="Foreground" Value="#B45309" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="FavoriteColumnStyle" TargetType="Border">
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="BorderThickness" Value="1,4,1,1" />
      <Setter Property="Margin" Value="0" />
    </Style>

    <DataTemplate x:Key="SelectionCellTemplate" DataType="{x:Type models:ActivityItem}">
      <Button Command="{Binding DataContext.ToggleSelectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
              CommandParameter="{Binding}"
              Style="{StaticResource SelectionCellButtonStyle}">
        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Focusable="False"
                  IsHitTestVisible="False" />
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="ActivityNameTemplate" DataType="{x:Type models:ActivityItem}">
      <Grid VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Width="30" Height="30" CornerRadius="7" BorderBrush="#DBE3EE" BorderThickness="1" Background="#F8FAFC" Margin="0,0,10,0">
          <Image Source="{Binding Icon}" Width="20" Height="20" Stretch="Uniform" />
        </Border>
        <StackPanel Grid.Column="1">
          <TextBlock Text="{Binding DisplayName}" FontSize="12.5" FontWeight="SemiBold" Foreground="#102033" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding SecondaryTitle}" Visibility="{Binding SecondaryTitleVisibility}" Foreground="{StaticResource MutedTextBrush}" FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
        </StackPanel>
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="ActivityActionsTemplate" DataType="{x:Type models:ActivityItem}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Content="{Binding FavoriteGlyph}"
                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"
                ToolTip="收藏或取消收藏"
                Style="{StaticResource FavoriteButtonStyle}"
                Margin="0,0,5,0" />
        <Button Content="关闭"
                Command="{Binding DataContext.CloseItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"
                ToolTip="正常关闭这个窗口"
                Style="{StaticResource CompactPrimaryButtonStyle}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="OfficeActionsTemplate" DataType="{x:Type models:ActivityItem}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Button Content="{Binding FavoriteGlyph}"
                Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"
                ToolTip="收藏或取消收藏"
                Style="{StaticResource FavoriteButtonStyle}"
                Margin="0,0,5,0" />
        <Button Content="关闭"
                Command="{Binding DataContext.CloseItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                CommandParameter="{Binding}"
                ToolTip="正常关闭这个窗口"
                Style="{StaticResource CompactPrimaryButtonStyle}" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="FavoriteCardTemplate" DataType="{x:Type models:FavoriteItem}">
      <Border Background="White" BorderBrush="#DDE6F2" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,7">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Width="28" Height="28" CornerRadius="7" BorderBrush="#DBE3EE" BorderThickness="1" Background="#F8FAFC" Margin="0,0,8,0">
            <Image Source="{Binding Icon}" Width="19" Height="19" Stretch="Uniform" />
          </Border>
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="{Binding DisplayName}" FontSize="12.5" FontWeight="Normal" Foreground="#102033" TextTrimming="CharacterEllipsis" />
            <TextBlock Text="{Binding Path}" Foreground="#2563EB" TextDecorations="Underline" FontSize="11.5" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
          </StackPanel>
          <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
            <Button Content="打开"
                    Command="{Binding DataContext.OpenFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    MinWidth="40"
                    Padding="6,3"
                    Margin="0,0,5,0" />
            <Button Content="移除"
                    Command="{Binding DataContext.RemoveFavoriteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    MinWidth="40"
                    Padding="6,3" />
          </StackPanel>
        </Grid>
      </Border>
    </DataTemplate>

    <Style x:Key="FavoriteEmptyStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#64748B" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="Margin" Value="10,12,10,0" />
    </Style>
  </Window.Resources>

  <DockPanel LastChildFill="True">
    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="16,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Border Width="62" Height="62" Background="Transparent" Margin="0,0,12,0">
            <Image Source="assets/app-logo.png" Width="60" Height="60" Stretch="Uniform" />
          </Border>
          <StackPanel>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="Winapp Management" FontSize="21" FontWeight="SemiBold" Foreground="#102033" />
              <TextBlock Text="{Binding AppVersion}" FontSize="11" Foreground="{StaticResource MutedTextBrush}" Margin="8,4,0,0" />
            </StackPanel>
            <TextBlock Text="{Binding SummaryText}" FontSize="11.5" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBox Width="292"
                   Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                   ToolTip="搜索应用、标题、路径或进程名" />
          <Button Content="刷新" Command="{Binding RefreshCommand}" Margin="8,0,0,0" />
          <Button Content="关闭选中" Command="{Binding CloseSelectedCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Margin="16" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="1">
      <TabControl Padding="10,8,10,10">
        <TabItem Style="{StaticResource AppTabItemStyle}">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="应用程序" FontSize="14" FontWeight="Bold" />
              <Border Style="{StaticResource BadgeStyle}" Background="#E2E8F0" Margin="10,0,0,0">
                <TextBlock Text="{Binding ApplicationCount}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </StackPanel>
          </TabItem.Header>
          <DataGrid x:Name="ApplicationDataGrid"
                    ItemsSource="{Binding Source={StaticResource ApplicationItemsViewSource}}"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                    SizeChanged="ApplicationDataGridSizeChanged"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.GroupStyle>
              <GroupStyle>
                <GroupStyle.HeaderTemplate>
                  <DataTemplate>
                    <Border Background="#F8FAFC" BorderBrush="{StaticResource SoftLineBrush}" BorderThickness="0,1,0,1" Padding="10,6">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#475569" />
                    </Border>
                  </DataTemplate>
                </GroupStyle.HeaderTemplate>
              </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="选择" CellTemplate="{StaticResource SelectionCellTemplate}" CellStyle="{StaticResource SelectionDataGridCellStyle}" Width="54" MinWidth="54" MaxWidth="54" />
              <DataGridTemplateColumn Header="名称" CellTemplate="{StaticResource ActivityNameTemplate}" Width="320" MinWidth="280" />
              <DataGridTextColumn Header="类型" Binding="{Binding KindLabel}" ElementStyle="{StaticResource CenterCellTextStyle}" Width="88" MinWidth="80" IsReadOnly="True" />
              <DataGridTemplateColumn Header="进程" Width="134" MinWidth="118">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="{Binding ProcessName}" Style="{StaticResource CellTextStyle}" FontWeight="Normal" />
                      <TextBlock Text="{Binding ProcessId, StringFormat=PID {0}}" Foreground="{StaticResource MutedTextBrush}" FontSize="11.5" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn x:Name="ApplicationPathColumn" Header="路径" Width="*" MinWidth="300">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Button Command="{Binding DataContext.ActivateItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"
                            Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                            Style="{StaticResource LinkButtonStyle}">
                      <Button.ContextMenu>
                        <ContextMenu>
                          <MenuItem Header="打开文件所在目录"
                                    Command="{Binding PlacementTarget.Tag.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                    CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                        </ContextMenu>
                      </Button.ContextMenu>
                      <TextBlock Text="{Binding DisplayPath}" HorizontalAlignment="Left" FontWeight="Normal" TextDecorations="Underline" TextTrimming="CharacterEllipsis" />
                    </Button>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="状态" Binding="{Binding Status}" ElementStyle="{StaticResource CenterCellTextStyle}" Width="88" MinWidth="76" IsReadOnly="True" />
              <DataGridTemplateColumn Header="操作" CellTemplate="{StaticResource ActivityActionsTemplate}" Width="112" MinWidth="112" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Style="{StaticResource OfficeTabItemStyle}">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Office文件" FontSize="14" FontWeight="Bold" />
              <Border Style="{StaticResource BadgeStyle}" Background="#DBEAFE" Margin="10,0,0,0">
                <TextBlock Text="{Binding OfficeCount}" FontSize="13" FontWeight="Bold" Foreground="#1D4ED8" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </StackPanel>
          </TabItem.Header>
          <DataGrid ItemsSource="{Binding Source={StaticResource OfficeItemsViewSource}}"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="选择" CellTemplate="{StaticResource SelectionCellTemplate}" CellStyle="{StaticResource SelectionDataGridCellStyle}" Width="54" MinWidth="54" MaxWidth="54" />
              <DataGridTemplateColumn Header="文件" CellTemplate="{StaticResource ActivityNameTemplate}" Width="350" MinWidth="300" />
              <DataGridTextColumn Header="类型" Binding="{Binding KindLabel}" ElementStyle="{StaticResource CenterCellTextStyle}" Width="92" MinWidth="84" IsReadOnly="True" />
              <DataGridTemplateColumn Header="进程" Width="134" MinWidth="118">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel VerticalAlignment="Center">
                      <TextBlock Text="{Binding ProcessName}" Style="{StaticResource CellTextStyle}" FontWeight="Normal" />
                      <TextBlock Text="{Binding ProcessId, StringFormat=PID {0}}" Foreground="{StaticResource MutedTextBrush}" FontSize="11.5" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTemplateColumn Header="文件目录" Width="*" MinWidth="300">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Grid>
                      <TextBlock Text="{Binding OfficeDirectoryDisplay}"
                                 Visibility="{Binding KnownOfficeDirectoryVisibility}"
                                 Style="{StaticResource CellTextStyle}"
                                 FontWeight="Normal"
                                 Foreground="#2563EB"
                                 TextDecorations="Underline"
                                 Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="打开文件所在目录"
                                      Command="{Binding PlacementTarget.Tag.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                          </ContextMenu>
                        </TextBlock.ContextMenu>
                      </TextBlock>
                      <Button Command="{Binding DataContext.ResolveOfficeDirectoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding}"
                              Visibility="{Binding UnknownOfficeDirectoryVisibility}"
                              Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                              Style="{StaticResource LinkButtonStyle}"
                              ToolTip="点击后手工选择这个 Office 窗口对应的文件">
                        <Button.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="打开文件所在目录"
                                      Command="{Binding PlacementTarget.Tag.OpenContainingFolderCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                          </ContextMenu>
                        </Button.ContextMenu>
                        <TextBlock Text="未识别目录，点击手工选择"
                                   FontWeight="Normal"
                                   Foreground="#94A3B8"
                                   TextDecorations="Underline"
                                   TextTrimming="CharacterEllipsis" />
                      </Button>
                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="状态" Binding="{Binding Status}" ElementStyle="{StaticResource CenterCellTextStyle}" Width="88" MinWidth="76" IsReadOnly="True" />
              <DataGridTemplateColumn Header="操作" CellTemplate="{StaticResource OfficeActionsTemplate}" Width="112" MinWidth="112" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Style="{StaticResource FavoriteTabItemStyle}">
          <TabItem.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="收藏" FontSize="14" FontWeight="Bold" />
              <Border Style="{StaticResource BadgeStyle}" Background="#E2E8F0" Margin="10,0,0,0">
                <TextBlock Text="{Binding Favorites.Count}" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
            </StackPanel>
          </TabItem.Header>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource FavoriteColumnStyle}" BorderBrush="#BFDBFE" Background="#EDF6FF" Margin="0,0,7,0">
              <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" MinHeight="54" Background="#EFF6FF" BorderBrush="#DBE3EE" BorderThickness="0,0,0,1" Padding="12,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Grid Width="30" Height="30" Margin="0,0,8,0">
                        <Border CornerRadius="7" BorderBrush="#BFDBFE" BorderThickness="1" Background="White" />
                        <Border Width="18" Height="12" CornerRadius="2" Background="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,4,0,0" />
                        <Border Width="9" Height="5" CornerRadius="2,2,0,0" Background="#FBBF24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8,8,0,0" />
                      </Grid>
                      <TextBlock Text="文件夹" FontSize="16" FontWeight="Bold" Foreground="#1F2A3D" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource BadgeStyle}" HorizontalAlignment="Right" Background="White" BorderBrush="#D8E8FF" BorderThickness="1">
                      <TextBlock Text="{Binding FolderFavoriteCount}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#1D4ED8" />
                    </Border>
                  </Grid>
                </Border>
                <Grid>
                  <TextBlock Text="暂无文件夹收藏" Visibility="{Binding FolderFavoritesEmptyVisibility}" Style="{StaticResource FavoriteEmptyStyle}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding FolderFavorites}" ItemTemplate="{StaticResource FavoriteCardTemplate}" Margin="10" />
                  </ScrollViewer>
                </Grid>
              </DockPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource FavoriteColumnStyle}" BorderBrush="#C7D2FE" Background="#F5F0FF" Margin="7,0">
              <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" MinHeight="54" Background="#F3E8FF" BorderBrush="#DBE3EE" BorderThickness="0,0,0,1" Padding="12,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Grid Width="30" Height="30" Margin="0,0,8,0">
                        <Border CornerRadius="7" BorderBrush="#C7D2FE" BorderThickness="1" Background="White" />
                        <Border Width="11" Height="14" CornerRadius="3" Background="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0" />
                        <Border Width="11" Height="14" CornerRadius="3" Background="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,5,0,0" />
                        <Border Width="11" Height="14" CornerRadius="3" Background="#EA580C" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <Border Width="12" Height="16" CornerRadius="3" Background="#DDE6FF" Opacity="0.85" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Grid>
                      <TextBlock Text="Office文件" FontSize="16" FontWeight="Bold" Foreground="#1F2A3D" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource BadgeStyle}" HorizontalAlignment="Right" Background="White" BorderBrush="#E9D5FF" BorderThickness="1">
                      <TextBlock Text="{Binding OfficeFavoriteCount}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#7C3AED" />
                    </Border>
                  </Grid>
                </Border>
                <Grid>
                  <TextBlock Text="暂无 Office 收藏" Visibility="{Binding OfficeFavoritesEmptyVisibility}" Style="{StaticResource FavoriteEmptyStyle}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding OfficeFavorites}" ItemTemplate="{StaticResource FavoriteCardTemplate}" Margin="10" />
                  </ScrollViewer>
                </Grid>
              </DockPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource FavoriteColumnStyle}" BorderBrush="#F3C96B" Background="#FFF8E6" Margin="7,0,0,0">
              <DockPanel LastChildFill="True">
                <Border DockPanel.Dock="Top" MinHeight="54" Background="#FFF7ED" BorderBrush="#DBE3EE" BorderThickness="0,0,0,1" Padding="12,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Grid Width="30" Height="30" Margin="0,0,8,0">
                        <Border CornerRadius="7" BorderBrush="#F3C96B" BorderThickness="1" Background="White" />
                        <Grid Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                          <Ellipse Width="22" Height="22" Fill="#EFF6FF" />
                          <Rectangle Width="9" Height="9" RadiusX="3" RadiusY="3" Fill="#2563EB" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="2,2,0,0" />
                          <Rectangle Width="9" Height="9" RadiusX="3" RadiusY="3" Fill="#38BDF8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0" />
                          <Rectangle Width="9" Height="9" RadiusX="3" RadiusY="3" Fill="#6366F1" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="2,0,0,2" />
                          <Rectangle Width="9" Height="9" RadiusX="3" RadiusY="3" Fill="#1D4ED8" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,2,2" />
                        </Grid>
                      </Grid>
                      <TextBlock Text="应用程序" FontSize="16" FontWeight="Bold" Foreground="#1F2A3D" VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="2" Style="{StaticResource BadgeStyle}" HorizontalAlignment="Right" Background="White" BorderBrush="#FDE68A" BorderThickness="1">
                      <TextBlock Text="{Binding ApplicationFavoriteCount}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#B45309" />
                    </Border>
                  </Grid>
                </Border>
                <Grid>
                  <TextBlock Text="暂无应用收藏" Visibility="{Binding ApplicationFavoritesEmptyVisibility}" Style="{StaticResource FavoriteEmptyStyle}" />
                  <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ApplicationFavorites}" ItemTemplate="{StaticResource FavoriteCardTemplate}" Margin="10" />
                  </ScrollViewer>
                </Grid>
              </DockPanel>
            </Border>
          </Grid>
        </TabItem>
      </TabControl>
    </Border>
  </DockPanel>
</Window>
